{
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/dashboard",
            "destination": "/dashboard.html"
        },
        {
            "source": "/student-dashboard",
            "destination": "/student-dashboard.html"
        }
    ],
    "headers": [
        {
            "source": "**",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        }
    ]
}